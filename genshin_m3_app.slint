import { Window, VerticalBox, HorizontalBox, Button, Text, Rectangle } from "std-widgets.slint";

export component GenshinM3App inherits Window {
    width: 900px;
    height: 700px;
    title: "Genshin Impact Rich Presence v4.0";
    
    property <string> current-tab: "main";
    property <string> game-status: "Not running";
    property <string> current-character: "None";
    property <string> current-location: "Unknown";
    property <string> uptime: "00:00:00";
    property <string> log-text: "";
    property <bool> rpc-running: false;
    
    preferred-width: 900px;
    preferred-height: 700px;
    
    /* Sidebar */
    Rectangle {
        x: 0px;
        y: 0px;
        width: 220px;
        height: parent.height;
        background: #6750A4;
        
        VerticalBox {
            padding: 16px;
            spacing: 12px;
            
            Text {
                text: "Genshin Impact\nRich Presence";
                font-size: 18px;
                font-weight: 700px;
                color: white;
            }
            
            Button {
                text: rpc-running ? "Stop" : "Start Rich Presence";
                clicked => {
                    self.stop-rpc();
                }
            }
            
            Text {
                text: rpc-running ? "Status: Running" : "Status: Stopped";
                color: white;
            }
            
            Text {
                text: "v4.0 M3";
                color: white;
                font-size: 12px;
            }
        }
    }
    
    /* Main content */
    Rectangle {
        x: 220px;
        y: 0px;
        width: parent.width - 220px;
        height: parent.height;
        background: #FFFBFE;
        
        /* Main Tab */
        if (current-tab == "main") {
            VerticalBox {
                padding: 24px;
                spacing: 16px;
                
                Text {
                    text: "Status";
                    font-size: 24px;
                    font-weight: 700px;
                }
                
                Rectangle {
                    background: #E7E0EC;
                    padding: 16px;
                    border-radius: 12px;
                    
                    VerticalBox {
                        spacing: 8px;
                        
                        HorizontalBox {
                            Text { text: "Game:"; font-weight: 700px; }
                            Text { text: game-status; }
                        }
                        
                        HorizontalBox {
                            Text { text: "Character:"; font-weight: 700px; }
                            Text { text: current-character; }
                        }
                        
                        HorizontalBox {
                            Text { text: "Location:"; font-weight: 700px; }
                            Text { text: current-location; }
                        }
                        
                        HorizontalBox {
                            Text { text: "Uptime:"; font-weight: 700px; }
                            Text { text: uptime; }
                        }
                    }
                }
                
                Button {
                    text: rpc-running ? "Stop" : "Start";
                    clicked => {
                        if (rpc-running) {
                            self.stop-rpc();
                        } else {
                            self.start-rpc();
                        }
                    }
                }
                
                Text {
                    text: "Activity Log";
                    font-size: 18px;
                    font-weight: 700px;
                }
                
                Rectangle {
                    background: #E7E0EC;
                    height: 150px;
                    padding: 8px;
                    border-radius: 12px;
                    
                    Text {
                        text: log-text;
                        wrap: true;
                        font-size: 12px;
                    }
                }
            }
        }
        
        /* Config Tab */
        if (current-tab == "config") {
            VerticalBox {
                padding: 24px;
                spacing: 16px;
                
                Text {
                    text: "Configuration";
                    font-size: 24px;
                    font-weight: 700px;
                }
                
                Rectangle {
                    background: #E7E0EC;
                    padding: 16px;
                    border-radius: 12px;
                    
                    VerticalBox {
                        spacing: 12px;
                        
                        Text {
                            text: "User Settings";
                            font-weight: 700px;
                        }
                        
                        Text { text: "Username: (configure in CONFIG.py)"; }
                        Text { text: "GPU Acceleration: (configure in CONFIG.py)"; }
                    }
                }
            }
        }
        
        /* About Tab */
        if (current-tab == "about") {
            VerticalBox {
                padding: 24px;
                spacing: 16px;
                
                Text {
                    text: "About";
                    font-size: 24px;
                    font-weight: 700px;
                }
                
                Rectangle {
                    background: #E7E0EC;
                    padding: 24px;
                    border-radius: 12px;
                    
                    VerticalBox {
                        spacing: 8px;
                        
                        Text {
                            text: "Genshin Impact Rich Presence";
                            font-weight: 700px;
                        }
                        
                        Text { text: "v4.0 Material 3 UI"; }
                        
                        Text { text: ""; }
                        
                        Text {
                            text: "Display your in-game activity on Discord.\n\nCreated by ZANdewanai";
                            wrap: true;
                        }
                    }
                }
            }
        }
    }
    
    /* Navigation */
    HorizontalBox {
        x: 220px;
        y: parent.height - 64px;
        width: parent.width - 220px;
        height: 64px;
        background: #FFFBFE;
        
        spacing: 8px;
        padding: 8px;
        
        Button {
            text: "Main";
            clicked => { current-tab = "main"; }
        }
        
        Button {
            text: "Config";
            clicked => { current-tab = "config"; }
        }
        
        Button {
            text: "About";
            clicked => { current-tab = "about"; }
        }
    }
}